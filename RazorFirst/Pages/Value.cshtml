@page "{value:int}"
@model RazorFirst.Pages.ValueModel
@{
}
@if (!string.IsNullOrEmpty(Model.Success))
{
<div class="alert alert-success" role="alert">
    @Model.Success
</div>
}
<p>
    <a asp-page-handler="Decrease" asp-route-value="@Model.Value">-</a> 
    @Model.Value 
    <a asp-page-handler="Increase" asp-route-value="@Model.Value">+</a>
    <a asp-page="" asp-route-value="10">10</a>
    <a asp-page="/Set">Nastavit</a>
    @if (Model.Value % 2 == 0)
    {
        <span>Hodnota je sudá.</span>
    }
    else
    {
        <span>Hodnota je lichá.</span>
    }
</p>